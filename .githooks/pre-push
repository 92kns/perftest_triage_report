#!/bin/sh
GREEN='\033[0;32m'
RED='\033[0;31m'
RESET='\033[0m'

echo "Running tests before push..."
if go test ./...; then
    printf "${GREEN}All tests passed.${RESET}\n"
else
    printf "${RED}Tests failed. Push aborted.${RESET}\n"
    exit 1
fi

if command -v golangci-lint >/dev/null 2>&1; then
    echo "Running linter..."
    if golangci-lint run; then
        printf "${GREEN}Lint passed.${RESET}\n"
    else
        printf "${RED}Lint failed. Push aborted.${RESET}\n"
        exit 1
    fi
else
    printf "golangci-lint not installed, skipping lint.\n"
fi
